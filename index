}
.nav-item svg { flex-shrink: 0; opacity: .7; }
.nav-item:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.85); }
.nav-item.active { background: rgba(26,111,196,.25); color: #fff; border-left-color: #1a6fc4; }
.nav-item.active svg { opacity: 1; }
.sidebar-footer {
  margin-top: auto; padding: 14px 18px;
  border-top: 1px solid rgba(255,255,255,.08);
}
.user-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.user-av {
  width: 30px; height: 30px; border-radius: 50%; background: #1a6fc4;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; color: #fff; flex-shrink: 0;
}
.user-name { font-size: 12px; font-weight: 600; color: #fff; }
.user-role { font-size: 10.5px; color: rgba(255,255,255,.4); }
.btn-logout {
  display: flex; align-items: center; gap: 8px;
  width: 100%; background: none; border: none;
  color: rgba(255,255,255,.45); font-size: 12px; cursor: pointer;
  padding: 6px 0; font-family: inherit;
}
.btn-logout:hover { color: rgba(255,255,255,.8); }

/* ---- MAIN CONTENT ---- */
.main {
  flex: 1; min-width: 0; height: 100vh;
  overflow-y: auto; display: flex; flex-direction: column;
}
.topbar {
  background: #fff; border-bottom: 1px solid #e2e8f0;
  padding: 14px 28px; display: flex; justify-content: space-between; align-items: center;
  flex-shrink: 0;
}
.page-title { font-size: 15px; font-weight: 700; color: #0f2744; }
.page-sub { font-size: 11.5px; color: #8492a6; margin-top: 1px; }
.topbar-right { display: flex; align-items: center; gap: 10px; }
.live-pill {
  display: flex; align-items: center; gap: 6px;
  background: #f0fdf4; border: 1px solid #bbf7d0;
  padding: 4px 10px; border-radius: 20px; font-size: 11.5px; color: #15803d; font-weight: 500;
}
.live-dot { width: 6px; height: 6px; border-radius: 50%; background: #16a34a; animation: blink 1.8s infinite; }
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.3;} }

.content { padding: 22px 28px; flex: 1; }

/* ---- METRIC CARDS ---- */
.metric-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 18px; }
.metric-card {
  background: #fff; border: 1px solid #e2e8f0; border-radius: 4px;
  padding: 18px 20px; position: relative; overflow: hidden;
}
.metric-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
}
.metric-card.blue::before { background: #1a6fc4; }
.metric-card.green::before { background: #16a34a; }
.metric-card.orange::before { background: #ea580c; }
.metric-card.slate::before { background: #64748b; }
.metric-label { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #8492a6; margin-bottom: 10px; }
.metric-value { font-size: 26px; font-weight: 700; color: #0f2744; line-height: 1; margin-bottom: 8px; }
.metric-sub { font-size: 11.5px; color: #8492a6; display: flex; align-items: center; gap: 4px; }
.metric-sub.up { color: #16a34a; }
.metric-sub.down { color: #dc2626; }
.metric-sub.warn { color: #ea580c; }

/* ---- CHARTS ROW ---- */
.charts-row { display: grid; grid-template-columns: 1.5fr 1fr; gap: 14px; margin-bottom: 18px; }
.chart-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 4px; padding: 18px 20px; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.card-title { font-size: 12.5px; font-weight: 700; color: #0f2744; }
.card-meta { font-size: 11px; color: #8492a6; }
.chart-wrap { position: relative; }

/* ---- ACTIVITY TABLE ---- */
.activity-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden; }
.activity-table { width: 100%; border-collapse: collapse; }
.activity-table th {
  text-align: left; font-size: 10.5px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .06em; color: #8492a6; background: #f8fafc;
  padding: 10px 16px; border-bottom: 1px solid #e2e8f0;
}
.activity-table td { padding: 10px 16px; border-bottom: 1px solid #f0f2f5; font-size: 12.5px; color: #1a2332; vertical-align: middle; }
.activity-table tr:last-child td { border-bottom: none; }
.activity-table tr:hover td { background: #f8fafc; }
.status-pill {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 20px;
}
.pill-done { background: #f0fdf4; color: #15803d; }
.pill-proses { background: #fffbeb; color: #b45309; }
.pill-pending { background: #eff6ff; color: #1d4ed8; }
.pill-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

/* ---- DATA LOGISTIK PAGE ---- */
.page-toolbar {
  background: #fff; border: 1px solid #e2e8f0; border-radius: 4px;
  padding: 14px 18px; display: flex; align-items: center; gap: 10px;
  margin-bottom: 14px; flex-wrap: wrap;
}
.search-wrap {
  flex: 1; min-width: 200px; display: flex; align-items: center; gap: 8px;
  border: 1px solid #d1d9e0; border-radius: 3px; padding: 7px 12px;
}
.search-wrap input { border: none; outline: none; flex: 1; font-size: 12.5px; color: #1a2332; font-family: inherit; }
.select-filter {
  border: 1px solid #d1d9e0; border-radius: 3px; padding: 7px 10px;
  font-size: 12.5px; color: #4a5568; outline: none; font-family: inherit;
}
.btn-add {
  display: flex; align-items: center; gap: 6px;
  background: #1a6fc4; color: #fff; border: none;
  padding: 8px 14px; border-radius: 3px; font-size: 12.5px; font-weight: 600;
  cursor: pointer; white-space: nowrap; transition: background .12s; font-family: inherit;
}
.btn-add:hover { background: #1558a0; }
.data-table-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden; }
.data-table { width: 100%; border-collapse: collapse; font-size: 12.5px; table-layout: fixed; }
.data-table th {
  text-align: left; font-size: 10.5px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .06em; color: #8492a6; background: #f8fafc;
  padding: 10px 14px; border-bottom: 1px solid #e2e8f0; white-space: nowrap;
}
.data-table td { padding: 10px 14px; border-bottom: 1px solid #f0f2f5; color: #1a2332; vertical-align: middle; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: #f8fafc; }
.cell-mono { font-family: "Courier New", monospace; font-size: 12px; color: #4a5568; }
.cell-muted { color: #6b7a90; }
.action-btns { display: flex; gap: 6px; }
.btn-icon-sm {
  width: 28px; height: 28px; border: none; border-radius: 3px;
  display: flex; align-items: center; justify-content: center; cursor: pointer;
}
.btn-edit-sm { background: #eff6ff; color: #1d4ed8; }
.btn-edit-sm:hover { background: #dbeafe; }
.btn-del-sm { background: #fef2f2; color: #dc2626; }
.btn-del-sm:hover { background: #fee2e2; }
.table-footer {
  padding: 9px 14px; display: flex; justify-content: space-between; align-items: center;
  border-top: 1px solid #e2e8f0; font-size: 11.5px; color: #8492a6;
}
.pagination { display: flex; gap: 4px; }
.pg-btn {
  min-width: 26px; height: 26px; border: 1px solid #e2e8f0;
  border-radius: 3px; background: #fff; font-size: 11.5px;
  color: #4a5568; display: flex; align-items: center; justify-content: center; cursor: pointer;
}
.pg-btn.active { background: #1a6fc4; color: #fff; border-color: #1a6fc4; }

/* ---- MODAL ---- */
.modal-bg {
  position: fixed; inset: 0; background: rgba(15,39,68,.55);
  display: flex; align-items: center; justify-content: center; z-index: 100;
}
.modal {
  background: #fff; border-radius: 4px; width: 440px; max-width: 96vw;
  box-shadow: 0 20px 60px rgba(0,0,0,.25); overflow: hidden;
}
.modal-head {
  padding: 18px 22px; border-bottom: 1px solid #e2e8f0;
  display: flex; justify-content: space-between; align-items: center;
}
.modal-head h3 { font-size: 14px; font-weight: 700; color: #0f2744; }
.btn-close { background: none; border: none; cursor: pointer; color: #8492a6; font-size: 18px; line-height: 1; }
.btn-close:hover { color: #1a2332; }
.modal-body { padding: 18px 22px; }
.form-field { margin-bottom: 14px; }
.form-label { display: block; font-size: 11.5px; font-weight: 600; color: #4a5568; margin-bottom: 5px; }
.form-control {
  width: 100%; border: 1px solid #d1d9e0; border-radius: 3px;
  padding: 8px 11px; font-size: 13px; color: #1a2332; outline: none; font-family: inherit;
}
.form-control:focus { border-color: #1a6fc4; box-shadow: 0 0 0 3px rgba(26,111,196,.12); }
.form-control.err { border-color: #dc2626; }
.field-err { font-size: 11px; color: #dc2626; margin-top: 4px; }
.modal-foot {
  padding: 14px 22px; border-top: 1px solid #e2e8f0;
  display: flex; justify-content: flex-end; gap: 8px;
}
.btn-cancel {
  padding: 8px 14px; border: 1px solid #d1d9e0; border-radius: 3px;
  background: #fff; font-size: 13px; font-weight: 500; color: #4a5568; cursor: pointer; font-family: inherit;
}
.btn-cancel:hover { background: #f8fafc; }
.btn-save {
  padding: 8px 16px; background: #1a6fc4; color: #fff; border: none;
  border-radius: 3px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit;
}
.btn-save:hover { background: #1558a0; }
.btn-del-confirm { background: #dc2626; color: #fff; }
.btn-del-confirm:hover { background: #b91c1c; }

/* ---- LAPORAN ---- */
.summary-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 18px; }
.wilayah-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
.wilayah-table th {
  text-align: left; font-size: 10.5px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .06em; color: #8492a6; background: #f8fafc;
  padding: 10px 16px; border-bottom: 1px solid #e2e8f0;
}
.wilayah-table td { padding: 10px 16px; border-bottom: 1px solid #f0f2f5; color: #1a2332; }
.wilayah-table tr:last-child td { border-bottom: none; }
.wilayah-table tr:hover td { background: #f8fafc; }
.eff-bar { display: flex; align-items: center; gap: 8px; }
.eff-track { flex: 1; height: 5px; background: #e2e8f0; border-radius: 10px; overflow: hidden; }
.eff-fill { height: 100%; border-radius: 10px; transition: width .3s; }
.eff-good { background: #16a34a; }
.eff-warn { background: #ea580c; }

/* ---- PENGGUNA PAGE ---- */
.user-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
.user-table th {
  text-align: left; font-size: 10.5px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .06em; color: #8492a6; background: #f8fafc;
  padding: 10px 16px; border-bottom: 1px solid #e2e8f0;
}
.user-table td { padding: 10px 16px; border-bottom: 1px solid #f0f2f5; }
.user-table tr:last-child td { border-bottom: none; }
.user-table tr:hover td { background: #f8fafc; }
.u-av {
  width: 28px; height: 28px; border-radius: 50%; background: #eff6ff; color: #1d4ed8;
  display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700;
}
.role-tag {
  display: inline-block; font-size: 10.5px; font-weight: 600;
  padding: 2px 8px; border-radius: 2px;
}
.role-admin { background: #eff6ff; color: #1d4ed8; }
.role-ops { background: #fffbeb; color: #b45309; }
.role-mgmt { background: #f0fdf4; color: #15803d; }

/* ---- TOAST ---- */
.toast {
  position: fixed; top: 18px; right: 20px; z-index: 999;
  background: #0f2744; color: #fff; padding: 11px 18px;
  border-radius: 3px; font-size: 13px; box-shadow: 0 8px 24px rgba(0,0,0,.2);
  display: flex; align-items: center; gap: 8px;
  animation: slideIn .2s ease;
}
.toast.ok { border-left: 3px solid #16a34a; }
.toast.err { border-left: 3px solid #dc2626; }
@keyframes slideIn { from { opacity:0; transform:translateY(-10px); } to { opacity:1; transform:translateY(0); } }

/* ---- INFO NOTE ---- */
.info-note {
  display: flex; align-items: flex-start; gap: 10px;
  background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 3px;
  padding: 11px 14px; font-size: 12px; color: #1e40af;
  margin-bottom: 14px; line-height: 1.5;
}
.info-note b { font-weight: 700; }
</style>
