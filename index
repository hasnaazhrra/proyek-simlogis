.field-input:focus { border-color: #1a6fc4; box-shadow: 0 0 0 3px rgba(26,111,196,.12); }
.field-input.err { border-color: #dc2626; }
.err-msg { font-size: 12px; color: #dc2626; margin-bottom: 10px; }
.btn-login {
