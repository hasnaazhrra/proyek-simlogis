function wilayahAgg(){
  var m={};
  STATE.logistik.forEach(function(d){
    if(!m[d.tujuan])m[d.tujuan]={j:0,b:0,s:0};
    m[d.tujuan].j++;m[d.tujuan].b+=d.biaya;if(d.status==='Selesai')m[d.tujuan].s++;
  });
