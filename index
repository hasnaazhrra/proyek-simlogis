.logo-text { font-size: 16px; font-weight: 700; color: #fff; letter-spacing: .06em; }
.login-headline { font-size: 22px; font-weight: 700; color: #fff; line-height: 1.3; margin-bottom: 12px; }
.login-sub { font-size: 13px; color: rgba(255,255,255,.55); line-height: 1.6; }
.login-footer { font-size: 11px; color: rgba(255,255,255,.3); border-top: 1px solid rgba(255,255,255,.1); padding-top: 16px; }
.login-right { flex: 1; padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; }
.login-right h2 { font-size: 19px; font-weight: 700; color: #0f2744; margin-bottom: 6px; }
.login-right .sub { font-size: 12.5px; color: #6b7a90; margin-bottom: 28px; }
.field-label { font-size: 11.5px; font-weight: 600; color: #4a5568; margin-bottom: 5px; display: block; letter-spacing: .02em; }
.field-input {
  width: 100%; border: 1px solid #d1d9e0; border-radius: 3px;
  padding: 9px 12px; font-size: 13.5px; color: #1a2332; outline: none;
  transition: border-color .15s, box-shadow .15s; margin-bottom: 14px;
