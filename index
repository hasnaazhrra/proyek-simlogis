.brand-name { font-size: 13.5px; font-weight: 700; color: #fff; letter-spacing: .06em; }
.brand-version { font-size: 10px; color: rgba(255,255,255,.35); margin-top: 1px; }
.nav-section { font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: rgba(255,255,255,.28); padding: 18px 18px 6px; }
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 18px; color: rgba(255,255,255,.58); font-size: 12.5px; font-weight: 500;
