      <div class="modal-head"><h3>Hapus Data Logistik</h3><button class="btn-close" id="m-close">&times;</button></div>
      <div class="modal-body"><p style="font-size:13px;color:#4a5568;line-height:1.6;">Anda akan menghapus data <b>${esc(item.nama)}</b> (#${item.id}) tujuan <b>${esc(item.tujuan)}</b>.<br>Tindakan ini <b>tidak dapat dibatalkan</b>.</p></div>
      <div class="modal-foot"><button class="btn-cancel" id="m-cancel">Batal</button><button class="btn-save btn-del-confirm" id="m-del">Hapus Data</button></div>
    </div></div>`;
  document.getElementById('m-close').onclick=closeModal;
  document.getElementById('m-cancel').onclick=closeModal;
  document.getElementById('m-del').onclick=function(){STATE.logistik=STATE.logistik.filter(function(d){return d.id!==id;});toast('Data berhasil dihapus','ok');closeModal();renderLogistik();};
}

// ===== LAPORAN =====
function renderLaporan(){
  var data=STATE.logistik,total=data.length;
  var totalB=data.reduce(function(s,d){return s+d.biaya;},0);
  var sel=data.filter(function(d){return d.status==='Selesai';}).length;
  var rata=total?Math.round(sel/total*100):0;
  var wil=wilayahAgg();

  document.getElementById('content').innerHTML=`
    <div class="summary-grid">
      <div class="metric-card blue"><div class="metric-label">Total Pengiriman</div><div class="metric-value">${total}</div><div class="metric-sub">seluruh wilayah</div></div>
      <div class="metric-card green"><div class="metric-label">Total Biaya</div><div class="metric-value">${fmtRp(totalB)}</div><div class="metric-sub">akumulasi semua data</div></div>
      <div class="metric-card ${rata>=85?'green':'orange'}"><div class="metric-label">Rata-rata Efisiensi</div><div class="metric-value">${rata}%</div><div class="metric-sub ${rata>=85?'up':'down'}">${rata>=85?'Di atas':'Di bawah'} target 85%</div></div>
    </div>
    <div class="chart-card" style="margin-bottom:16px;">
      <div class="card-header">
        <span class="card-title">Jumlah pengiriman per wilayah tujuan</span>
        <span class="card-meta">${wil.length} wilayah aktif</span>
      </div>
      <div class="chart-wrap" style="height:200px;"><canvas id="c-wil" role="img" aria-label="Grafik distribusi pengiriman per wilayah"></canvas></div>
    </div>
    <div class="data-table-card">
      <table class="wilayah-table">
        <thead><tr><th>Wilayah Tujuan</th><th>Jumlah Pengiriman</th><th>Total Biaya</th><th>Efisiensi</th><th>Bar Efisiensi</th></tr></thead>
        <tbody>${wil.map(function(w){return`<tr>
          <td style="font-weight:600">${esc(w.t)}</td>
          <td class="cell-muted">${w.j} pengiriman</td>
          <td class="cell-mono">${fmtRp(w.b)}</td>
          <td><span style="font-weight:700;color:${w.e>=85?'#16a34a':'#ea580c'};">${w.e}%</span></td>
          <td style="width:160px"><div class="eff-bar"><div class="eff-track"><div class="eff-fill ${w.e>=85?'eff-good':'eff-warn'}" style="width:${w.e}%"></div></div></div></td>
        </tr>`;}).join('')}</tbody>
      </table>
    </div>`;

  if(STATE.chartRefs.wil)STATE.chartRefs.wil.destroy();
  STATE.chartRefs.wil=new Chart(document.getElementById('c-wil'),{type:'bar',data:{labels:wil.map(function(w){return w.t;}),datasets:[{data:wil.map(function(w){return w.j;}),backgroundColor:'#0f2744',borderRadius:3,label:'Pengiriman'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{ticks:{font:{size:10},stepSize:1},grid:{color:'#f0f2f5'}},x:{ticks:{font:{size:10}},grid:{display:false}}}}});
}

// ===== PENGGUNA =====
function renderPengguna(){
  var total=STATE.users.length,aktif=STATE.users.filter(function(u){return u.status==='Aktif';}).length;
  document.getElementById('content').innerHTML=`
    <div class="summary-grid">
      <div class="metric-card slate"><div class="metric-label">Total Pengguna</div><div class="metric-value">${total}</div><div class="metric-sub">seluruh akun terdaftar</div></div>
      <div class="metric-card green"><div class="metric-label">Aktif</div><div class="metric-value">${aktif}</div><div class="metric-sub up">&#x2714; Dapat mengakses sistem</div></div>
      <div class="metric-card orange"><div class="metric-label">Non-aktif</div><div class="metric-value">${total-aktif}</div><div class="metric-sub">${total-aktif===0?'Tidak ada akun non-aktif':'Akses dibekukan'}</div></div>
    </div>
    <div class="page-toolbar">
      <span style="font-size:12px;color:#4a5568;font-weight:600;">Daftar Pengguna</span>
      <div style="flex:1"></div>
      <button class="btn-add">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="17" y1="11" x2="23" y2="11"/></svg>
        Tambah Pengguna
      </button>
    </div>
    <div class="data-table-card">
      <table class="user-table">
        <thead><tr><th>Pengguna</th><th>Email</th><th>Role</th><th>Status</th></tr></thead>
        <tbody>${STATE.users.map(function(u){return`<tr>
          <td><div style="display:flex;align-items:center;gap:10px;"><div class="u-av">${ini(u.nama)}</div><div><div style="font-weight:600">${esc(u.nama)}</div></div></div></td>
          <td class="cell-muted">${esc(u.email)}</td>
          <td><span class="role-tag ${u.role==='Admin'?'role-admin':u.role==='Operasional'?'role-ops':'role-mgmt'}">${u.role}</span></td>
          <td><span class="status-pill ${u.status==='Aktif'?'pill-done':'pill-pending'}"><span class="pill-dot"></span>${u.status}</span></td>
        </tr>`;}).join('')}</tbody>
      </table>
    </div>`;
}

// fix modal-bg click
document.addEventListener('click',function(e){if(e.target&&e.target.classList.contains('modal-bg'))closeModal();});
</script>
</body>
</html>
