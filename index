}
.login-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 40px; }
.logo-mark {
  width: 36px; height: 36px; background: #1a6fc4;
  border-radius: 3px; display: flex; align-items: center; justify-content: center;
