  padding: 10px; font-size: 14px; font-weight: 600; border-radius: 3px;
  cursor: pointer; letter-spacing: .02em; transition: background .12s;
}
.btn-login:hover { background: #1558a0; }
.demo-hint {
  margin-top: 20px; padding: 12px 14px;
  background: #f7f9fc; border: 1px solid #e2e8f0; border-radius: 3px;
  font-size: 11.5px; color: #6b7a90; line-height: 1.7;
}
.demo-hint b { color: #1a2332; }
.demo-hint code { font-family: "Courier New", monospace; background: #fff; border: 1px solid #e2e8f0; padding: 1px 4px; border-radius: 2px; font-size: 11px; }

/* ---- APP SHELL ---- */
#app {
  display: none; width: 100vw; height: 100vh;
  flex-direction: row; overflow: hidden;
}
#app.active { display: flex; }

/* ---- SIDEBAR ---- */
.sidebar {
  width: 220px; flex-shrink: 0;
  background: #0f2744; height: 100vh;
  display: flex; flex-direction: column;
  overflow: hidden;
}
.sidebar-brand {
